RS08 — Las condiciones (if, while, for) solo pueden comparar valores numéricos. 

Juego TestRS08 Mundo_abierto

Simulacion vida = 100
Simulacion_vida nombre = "Jugador"

Accion(nombre Estrategia vida) Mundo_abierto
    FPS("Esto no deberia ejecutarse")
